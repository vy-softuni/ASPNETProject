@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<section class="auth-stage auth-stage-login">
    <div class="auth-backdrop"></div>
    <div class="auth-stage-grid">
        <aside class="auth-showcase">
            <div class="auth-showcase-frame">
                <span class="eyebrow">🔐 Secure member access</span>
                <h1>Welcome back to RepairCircle</h1>
                <p>Sign in to manage repair requests, tool borrowings, favorite items, and volunteer activity from one polished dashboard.</p>
                <div class="auth-showcase-stats">
                    <div class="auth-stat-card"><strong>3</strong><span>Core roles</span></div>
                    <div class="auth-stat-card"><strong>Live</strong><span>Seat & tool updates</span></div>
                    <div class="auth-stat-card"><strong>Smart</strong><span>Search & filters</span></div>
                </div>
                <ul class="auth-feature-list auth-feature-list-fancy">
                    <li><span>🧰</span> View tool availability instantly</li>
                    <li><span>🛠️</span> Track the status of your repairs</li>
                    <li><span>⭐</span> Keep favorite tools close at hand</li>
                </ul>
            </div>
        </aside>

        <div class="auth-shell auth-shell-premium card elevated-card">
            <div class="auth-card-header auth-card-header-large">
                <div class="auth-pill">Member sign in</div>
                <div class="auth-icon-circle">🔑</div>
                <h2>Log in</h2>
                <p>Use your email address and password to continue.</p>
            </div>

            <form id="account" method="post" class="auth-form auth-form-premium">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>
                <input asp-for="Input.ReturnUrl" type="hidden" />

                <div class="form-field auth-field">
                    <label asp-for="Input.Email"></label>
                    <div class="auth-input-wrap fancy-auth-input"><span class="auth-input-icon">📧</span><input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="name@example.com" /></div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-field auth-field">
                    <label asp-for="Input.Password"></label>
                    <div class="auth-input-wrap fancy-auth-input"><span class="auth-input-icon">🔒</span><input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="Enter your password" /></div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="auth-form-row">
                    <label class="checkbox-label auth-checkbox" asp-for="Input.RememberMe">
                        <input asp-for="Input.RememberMe" /> @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                    <span class="auth-helper-text">Local account only</span>
                </div>

                <div class="actions auth-actions-stacked">
                    <button id="login-submit" type="submit" class="btn btn-primary btn-wide auth-main-button">Log in</button>
                    <a class="btn btn-secondary btn-wide auth-secondary-button" asp-page="./Register" asp-route-returnUrl="@Model.Input.ReturnUrl">Create account</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
