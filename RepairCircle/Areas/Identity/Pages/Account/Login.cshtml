@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<section class="auth-hero auth-hero-premium">
    <div class="auth-hero-copy">
        <span class="eyebrow">🔐 Welcome back</span>
        <h1>Sign in to RepairCircle</h1>
        <p>Access your repairs, borrowings, favorites, volunteer profile, and administration tools from one place.</p>
        <ul class="auth-feature-list">
            <li>Track your repair requests</li>
            <li>Manage borrowed tools</li>
            <li>Save favorite tools for later</li>
        </ul>
    </div>

    <div class="auth-shell card auth-card elevated-card">
        <div class="auth-card-header">
            <h2>Log in</h2><div class="auth-icon-circle">🔑</div>
            <p>Use your email and password to continue.</p>
        </div>

        <form id="account" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>
            <input asp-for="Input.ReturnUrl" type="hidden" />

            <div class="form-field">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="Enter your password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-field checkbox-field">
                <label class="checkbox-label" asp-for="Input.RememberMe">
                    <input asp-for="Input.RememberMe" /> @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>

            <div class="actions">
                <button id="login-submit" type="submit" class="btn btn-primary btn-wide">Log in</button>
                <a class="btn btn-secondary btn-wide" asp-page="./Register" asp-route-returnUrl="@Model.Input.ReturnUrl">Create account</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
