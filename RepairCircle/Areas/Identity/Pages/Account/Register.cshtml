@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="page-header card">
    <span class="eyebrow">Account</span>
    <h1>Create account</h1>
    <p>Create a local RepairCircle account. No external sign-in providers are used in this project.</p>
</section>

<div class="auth-shell single-auth card auth-card">
    <form id="registerForm" method="post" class="auth-form">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <input asp-for="Input.ReturnUrl" type="hidden" />
        <div class="form-field">
            <label asp-for="Input.FullName"></label>
            <input asp-for="Input.FullName" />
            <span asp-validation-for="Input.FullName" class="text-danger"></span>
        </div>
        <div class="form-field">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" autocomplete="username" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="form-field">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" autocomplete="new-password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="form-field">
            <label asp-for="Input.ConfirmPassword"></label>
            <input asp-for="Input.ConfirmPassword" autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>
        <div class="actions">
            <button id="registerSubmit" type="submit" class="btn btn-primary">Register</button>
            <a class="btn btn-secondary" asp-page="./Login" asp-route-returnUrl="@Model.Input.ReturnUrl">Back to login</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
