@model IEnumerable<Announcement>
@{
    ViewData["Title"] = "Admin Announcements";
}
<section class="card table-card">
    <div class="page-header-inline">
        <div>
            <span class="eyebrow">Administration</span>
            <h1>Announcements</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">Create announcement</a>
    </div>

    <form method="get" class="form-grid filter-grid admin-filter-form">
        <div class="form-field">
            <label for="searchTerm">Search</label>
            <input id="searchTerm" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Title or content..." />
        </div>
        <div class="form-field checkbox-field">
            <label class="checkbox-label">
                <input type="checkbox" name="onlyImportant" value="true" @((ViewBag.OnlyImportant == true) ? "checked" : null) />
                Only important
            </label>
        </div>
        <div class="form-field checkbox-field">
            <label class="checkbox-label">
                <input type="checkbox" name="onlyPublished" value="true" @((ViewBag.OnlyPublished == true) ? "checked" : null) />
                Only published
            </label>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="Index">Clear</a>
        </div>
    </form>

    <table>
        <thead>
            <tr><th>Title</th><th>Important</th><th>Published</th><th>Created</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var announcement in Model)
        {
            <tr>
                <td>@announcement.Title</td>
                <td>@(announcement.IsImportant ? "Yes" : "No")</td>
                <td>@(announcement.IsPublished ? "Yes" : "No")</td>
                <td>@announcement.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy")</td>
                <td>
                    <div class="table-actions">
                        <a asp-action="Edit" asp-route-id="@announcement.Id">Edit</a>
                        <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this announcement?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@announcement.Id" />
                            <button type="submit" class="btn-link-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<partial name="_PaginationPartial" model="(PaginationViewModel)ViewBag.Pagination" />
