@model IEnumerable<Announcement>
@{
    ViewData["Title"] = "Admin Announcements";
}
<partial name="~/Areas/Admin/Views/Shared/_AdminNavPartial.cshtml" />
<section class="card">
    <div class="actions" style="justify-content: space-between; align-items: center;">
        <h1>Announcements</h1>
        <a class="btn btn-primary" asp-action="Create">Create announcement</a>
    </div>
    <table>
        <thead>
            <tr><th>Title</th><th>Important</th><th>Published</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var announcement in Model)
        {
            <tr>
                <td>@announcement.Title</td>
                <td>@(announcement.IsImportant ? "Yes" : "No")</td>
                <td>@(announcement.IsPublished ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@announcement.Id">Edit</a>
                    <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this announcement?');">
                        <input type="hidden" name="id" value="@announcement.Id" />
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
