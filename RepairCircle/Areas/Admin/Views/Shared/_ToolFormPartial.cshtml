@model Tool
<div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
<div class="form-grid">
    <div class="form-field form-field-wide">
        <label asp-for="Name"></label>
        <input asp-for="Name" placeholder="Example: Precision screwdriver set" />
        <span asp-validation-for="Name"></span>
    </div>

    <div class="form-field form-field-wide">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" placeholder="Describe the tool, its condition, included parts, and any borrowing notes."></textarea>
        <span asp-validation-for="Description"></span>
    </div>

    <div class="form-field form-field-wide">
        <label asp-for="ImageUrl"></label>
        <input asp-for="ImageUrl" placeholder="https://example.com/tool-image.jpg or /uploads/tools/example.jpg" />
        <span asp-validation-for="ImageUrl"></span>
    </div>

    <div class="form-field form-field-wide">
        <label for="imageFile">Upload image</label>
        <input id="imageFile" name="imageFile" type="file" accept=".jpg,.jpeg,.png,.webp,.gif,image/*" />
        <small class="muted small-text">Optional. You can keep a direct image link above or upload a local file here. Supported formats: JPG, PNG, WEBP, GIF. Maximum size: 5 MB.</small>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <div class="form-field form-field-wide">
            <div class="image-preview-card">
                <span class="muted small-text">Current image</span>
                <img class="uploaded-image-preview" src="@Url.Content(Model.ImageUrl)" alt="Current tool image for @Model.Name" />
            </div>
        </div>
    }

    <div class="form-field">
        <label asp-for="Condition"></label>
        <select asp-for="Condition" asp-items="Html.GetEnumSelectList<RepairCircle.Data.Enums.ToolCondition>()"></select>
        <span asp-validation-for="Condition"></span>
    </div>

    <div class="form-field">
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" type="number" min="0" />
        <span asp-validation-for="Quantity"></span>
    </div>

    <div class="form-field">
        <label asp-for="ToolCategoryId"></label>
        <select asp-for="ToolCategoryId" asp-items="ViewBag.ToolCategories"></select>
        <span asp-validation-for="ToolCategoryId"></span>
    </div>

    <div class="form-field">
        <label asp-for="LocationId"></label>
        <select asp-for="LocationId" asp-items="ViewBag.Locations"></select>
        <span asp-validation-for="LocationId"></span>
    </div>

    <div class="form-field checkbox-field">
        <label class="checkbox-label"><input asp-for="IsAvailable" /> Available for borrowing</label>
    </div>
</div>
