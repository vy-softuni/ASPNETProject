@model Location
<div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
<div class="form-grid">
    <div class="form-field">
        <label asp-for="Name"></label>
        <input asp-for="Name" placeholder="Example: Sofia Community Workshop" />
        <span asp-validation-for="Name"></span>
    </div>
    <div class="form-field">
        <label asp-for="City"></label>
        <input asp-for="City" placeholder="Sofia" />
        <span asp-validation-for="City"></span>
    </div>
    <div class="form-field form-field-wide">
        <label asp-for="Address"></label>
        <input asp-for="Address" placeholder="Street, number, district" />
        <span asp-validation-for="Address"></span>
    </div>
    <div class="form-field form-field-wide">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" placeholder="Add notes about parking, workshop access, opening hours, or pickup rules."></textarea>
        <span asp-validation-for="Description"></span>
    </div>
    <div class="form-field">
        <label asp-for="Latitude"></label>
        <input asp-for="Latitude" type="number" step="0.000001" placeholder="42.697708" />
        <span asp-validation-for="Latitude"></span>
    </div>
    <div class="form-field">
        <label asp-for="Longitude"></label>
        <input asp-for="Longitude" type="number" step="0.000001" placeholder="23.321868" />
        <span asp-validation-for="Longitude"></span>
    </div>
</div>
<p class="muted small-text top-margin-half">When latitude and longitude are provided, public location-aware pages can render an embedded Google Map automatically.</p>
