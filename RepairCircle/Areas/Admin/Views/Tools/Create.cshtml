@model Tool
@{
    ViewData["Title"] = "Create Tool";
}
<partial name="~/Areas/Admin/Views/Shared/_AdminNavPartial.cshtml" />
<section class="card">
    <h1>Create tool</h1>
    <form method="post">
        @Html.AntiForgeryToken()
        <partial name="~/Areas/Admin/Views/Shared/_ToolFormPartial.cshtml" model="Model" />
        <div class="actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-secondary" asp-action="Index">Back</a>
        </div>
    </form>
</section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
