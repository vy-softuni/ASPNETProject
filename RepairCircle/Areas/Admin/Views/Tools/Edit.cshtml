@model Tool
@{ ViewData["Title"] = "Edit Tool"; }
@model Tool
<partial name="~/Areas/Admin/Views/Shared/_AdminNavPartial.cshtml" />
<section class="card">
    <h1>@ViewData["Title"]</h1>
    <form method="post">
        <input asp-for="Id" type="hidden" />
        <label asp-for="Name"></label>
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>

        <label asp-for="Description"></label>
        <textarea asp-for="Description"></textarea>
        <span asp-validation-for="Description"></span>

        <label asp-for="ImageUrl"></label>
        <input asp-for="ImageUrl" />

        <label asp-for="Condition"></label>
        <select asp-for="Condition" asp-items="Html.GetEnumSelectList<RepairCircle.Data.Enums.ToolCondition>()"></select>

        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" type="number" />

        <label asp-for="ToolCategoryId">Category</label>
        <select asp-for="ToolCategoryId" asp-items="ViewBag.ToolCategories"></select>

        <label asp-for="LocationId">Location</label>
        <select asp-for="LocationId" asp-items="ViewBag.Locations"></select>

        <label><input asp-for="IsAvailable" /> Available</label>

        <div class="actions">
            <button type="submit">Save</button>
            <a class="btn btn-secondary" asp-action="Index">Back</a>
        </div>
    </form>
</section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
