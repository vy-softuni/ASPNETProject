@model IEnumerable<Tool>
@{
    ViewData["Title"] = "Admin Tools";
}
<partial name="~/Areas/Admin/Views/Shared/_AdminNavPartial.cshtml" />
<section class="card">
    <div class="actions" style="justify-content: space-between; align-items: center;">
        <h1>Tools</h1>
        <a class="btn btn-primary" asp-action="Create">Create tool</a>
    </div>
    <table>
        <thead>
            <tr><th>Name</th><th>Category</th><th>Location</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var tool in Model)
        {
            <tr>
                <td>@tool.Name</td>
                <td>@tool.ToolCategory.Name</td>
                <td>@tool.Location.Name</td>
                <td>@(tool.IsAvailable ? "Available" : "Unavailable")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@tool.Id">Edit</a>
                    <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this tool?');">
                        <input type="hidden" name="id" value="@tool.Id" />
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
