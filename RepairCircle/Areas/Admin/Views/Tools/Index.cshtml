@model IEnumerable<Tool>
@{
    ViewData["Title"] = "Admin Tools";
}
<section class="card table-card">
    <div class="page-header-inline">
        <div>
            <span class="eyebrow">Administration</span>
            <h1>Tools</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">Create tool</a>
    </div>
    <table>
        <thead>
            <tr><th>Name</th><th>Category</th><th>Location</th><th>Quantity</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var tool in Model)
        {
            <tr>
                <td>@tool.Name</td>
                <td>@tool.ToolCategory.Name</td>
                <td>@tool.Location.Name</td>
                <td>@tool.Quantity</td>
                <td><span class="status-badge @(tool.IsAvailable ? "status-success" : "status-muted")">@(tool.IsAvailable ? "Available" : "Unavailable")</span></td>
                <td>
                    <div class="table-actions">
                        <a asp-action="Edit" asp-route-id="@tool.Id">Edit</a>
                        <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this tool?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@tool.Id" />
                            <button type="submit" class="btn-link-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<partial name="_PaginationPartial" model="(PaginationViewModel)ViewBag.Pagination" />
