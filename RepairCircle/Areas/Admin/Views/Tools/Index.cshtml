@model IEnumerable<Tool>
@{
    ViewData["Title"] = "Admin Tools";
}
<section class="card table-card">
    <div class="page-header-inline">
        <div>
            <span class="eyebrow">Administration</span>
            <h1>Tools</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">Create tool</a>
    </div>

    <form method="get" class="form-grid filter-grid admin-filter-form">
        <div class="form-field">
            <label for="searchTerm">Search</label>
            <input id="searchTerm" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Tool, category, location..." />
        </div>
        <div class="form-field">
            <label for="categoryId">Category</label>
            <select id="categoryId" name="categoryId" asp-items="ViewBag.ToolCategories">
                <option value="">All categories</option>
            </select>
        </div>
        <div class="form-field">
            <label for="locationId">Location</label>
            <select id="locationId" name="locationId" asp-items="ViewBag.Locations">
                <option value="">All locations</option>
            </select>
        </div>
        <div class="form-field checkbox-field">
            <label class="checkbox-label">
                <input type="checkbox" name="onlyAvailable" value="true" @((ViewBag.OnlyAvailable == true) ? "checked" : null) />
                Only available
            </label>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="Index">Clear</a>
        </div>
    </form>

    <table>
        <thead>
            <tr><th>Name</th><th>Category</th><th>Location</th><th>Quantity</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var tool in Model)
        {
            <tr>
                <td>@tool.Name</td>
                <td>@tool.ToolCategory.Name</td>
                <td>@tool.Location.Name</td>
                <td>@tool.Quantity</td>
                <td><span class="status-badge @(tool.IsAvailable ? "status-success" : "status-muted")">@(tool.IsAvailable ? "Available" : "Unavailable")</span></td>
                <td>
                    <div class="table-actions">
                        <a asp-action="Edit" asp-route-id="@tool.Id">Edit</a>
                        <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this tool?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@tool.Id" />
                            <button type="submit" class="btn-link-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<partial name="_PaginationPartial" model="(PaginationViewModel)ViewBag.Pagination" />
