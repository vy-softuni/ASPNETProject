@model IEnumerable<RepairRequest>
@{
    ViewData["Title"] = "Admin Repair Requests";
}
<section class="card table-card">
    <div class="page-header-inline">
        <div>
            <span class="eyebrow">Administration</span>
            <h1>Repair requests</h1>
        </div>
    </div>
    <table>
        <thead>
            <tr><th>Title</th><th>Status</th><th>Submitted by</th><th>Volunteer</th><th>Location</th><th>Requested</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var request in Model)
        {
            <tr>
                <td>@request.Title</td>
                <td><span class="status-badge">@request.Status</span></td>
                <td>@(request.SubmittedByUser.FullName ?? request.SubmittedByUser.Email)</td>
                <td>@(request.AssignedVolunteerProfile?.User.FullName ?? request.AssignedVolunteerProfile?.User.Email ?? "Not assigned")</td>
                <td>@request.Location.Name</td>
                <td>@request.RequestedDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                <td><a asp-action="Details" asp-route-id="@request.Id">Manage</a></td>
            </tr>
        }
        </tbody>
    </table>
</section>

<partial name="_PaginationPartial" model="(PaginationViewModel)ViewBag.Pagination" />
