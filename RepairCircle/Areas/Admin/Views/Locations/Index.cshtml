@model IEnumerable<Location>
@{
    ViewData["Title"] = "Admin Locations";
}
<section class="card table-card">
    <div class="page-header-inline">
        <div>
            <span class="eyebrow">Administration</span>
            <h1>Locations</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">Create location</a>
    </div>

    <form method="get" class="form-grid filter-grid admin-filter-form">
        <div class="form-field">
            <label for="searchTerm">Search</label>
            <input id="searchTerm" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Workshop name, address..." />
        </div>
        <div class="form-field">
            <label for="city">City</label>
            <input id="city" name="city" value="@ViewBag.City" placeholder="Sofia" />
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="Index">Clear</a>
        </div>
    </form>

    <table>
        <thead>
            <tr><th>Name</th><th>City</th><th>Address</th><th>Coordinates</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var location in Model)
        {
            <tr>
                <td>@location.Name</td>
                <td>@location.City</td>
                <td>@location.Address</td>
                <td>@(location.Latitude.HasValue && location.Longitude.HasValue ? $"{location.Latitude}, {location.Longitude}" : "—")</td>
                <td>
                    <div class="table-actions">
                        <a asp-action="Edit" asp-route-id="@location.Id">Edit</a>
                        <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this location?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@location.Id" />
                            <button type="submit" class="btn-link-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<partial name="_PaginationPartial" model="(PaginationViewModel)ViewBag.Pagination" />
