@model IEnumerable<RepairSession>
@{
    ViewData["Title"] = "Admin Repair Sessions";
}
<partial name="~/Areas/Admin/Views/Shared/_AdminNavPartial.cshtml" />
<section class="card">
    <div class="actions" style="justify-content: space-between; align-items: center;">
        <h1>Repair Sessions</h1>
        <a class="btn btn-primary" asp-action="Create">Create session</a>
    </div>
    <table>
        <thead>
            <tr><th>Title</th><th>Start</th><th>Location</th><th>Slots</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var session in Model)
        {
            <tr>
                <td>@session.Title</td>
                <td>@session.StartDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td>@session.Location.Name</td>
                <td>@session.AvailableSlots / @session.MaxParticipants</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@session.Id">Edit</a>
                    <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this session?');">
                        <input type="hidden" name="id" value="@session.Id" />
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
