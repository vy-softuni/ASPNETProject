@model IEnumerable<RepairSession>
@{
    ViewData["Title"] = "Admin Repair Sessions";
}
<section class="card table-card">
    <div class="page-header-inline">
        <div>
            <span class="eyebrow">Administration</span>
            <h1>Repair sessions</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">Create session</a>
    </div>

    <form method="get" class="form-grid filter-grid admin-filter-form">
        <div class="form-field">
            <label for="searchTerm">Search</label>
            <input id="searchTerm" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Session title, workshop..." />
        </div>
        <div class="form-field">
            <label for="locationId">Location</label>
            <select id="locationId" name="locationId" asp-items="ViewBag.Locations">
                <option value="">All locations</option>
            </select>
        </div>
        <div class="form-field checkbox-field">
            <label class="checkbox-label">
                <input type="checkbox" name="onlyUpcoming" value="true" @((ViewBag.OnlyUpcoming == true) ? "checked" : null) />
                Only upcoming
            </label>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="Index">Clear</a>
        </div>
    </form>

    <table>
        <thead>
            <tr><th>Title</th><th>Start</th><th>End</th><th>Location</th><th>Slots</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var session in Model)
        {
            <tr>
                <td>@session.Title</td>
                <td>@session.StartDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td>@session.EndDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td>@session.Location.Name</td>
                <td>@session.AvailableSlots / @session.MaxParticipants</td>
                <td>
                    <div class="table-actions">
                        <a asp-action="Edit" asp-route-id="@session.Id">Edit</a>
                        <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this session?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@session.Id" />
                            <button type="submit" class="btn-link-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<partial name="_PaginationPartial" model="(PaginationViewModel)ViewBag.Pagination" />
