@model RepairSession
@{ ViewData["Title"] = "Edit Repair Session"; }
@model RepairSession
<partial name="~/Areas/Admin/Views/Shared/_AdminNavPartial.cshtml" />
<section class="card">
    <h1>@ViewData["Title"]</h1>
    <form method="post">
        <input asp-for="Id" type="hidden" />
        <label asp-for="Title"></label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>

        <label asp-for="Description"></label>
        <textarea asp-for="Description"></textarea>
        <span asp-validation-for="Description"></span>

        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="datetime-local" value="@Model.StartDate.ToString("yyyy-MM-ddTHH:mm")" />

        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="datetime-local" value="@Model.EndDate.ToString("yyyy-MM-ddTHH:mm")" />

        <label asp-for="MaxParticipants"></label>
        <input asp-for="MaxParticipants" type="number" />

        <label asp-for="AvailableSlots"></label>
        <input asp-for="AvailableSlots" type="number" />

        <label asp-for="LocationId">Location</label>
        <select asp-for="LocationId" asp-items="ViewBag.Locations"></select>

        <div class="actions">
            <button type="submit">Save</button>
            <a class="btn btn-secondary" asp-action="Index">Back</a>
        </div>
    </form>
</section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
