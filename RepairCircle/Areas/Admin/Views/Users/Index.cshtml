@model IEnumerable<AdminUserListItemViewModel>
@{
    ViewData["Title"] = "Users";
}
<section class="card table-card">
    <div class="page-header-inline">
        <div>
            <span class="eyebrow">Administration</span>
            <h2>Users and roles</h2>
            <p>Overview of registered users, volunteer accounts, and administrators.</p>
        </div>
    </div>

    <form method="get" class="form-grid filter-grid admin-filter-form">
        <div class="form-field">
            <label for="searchTerm">Search</label>
            <input id="searchTerm" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Name, username, email..." />
        </div>
        <div class="form-field">
            <label for="role">Role</label>
            <select id="role" name="role">
                <option value="">All roles</option>
                @foreach (var roleName in (IEnumerable<string>)ViewBag.Roles)
                {
                    @if (string.Equals((string?)ViewBag.Role, roleName, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@roleName" selected>@roleName</option>
                    }
                    else
                    {
                        <option value="@roleName">@roleName</option>
                    }
                }
            </select>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="Index">Clear</a>
        </div>
    </form>

    <table>
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Username</th>
                <th>Roles</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@(string.IsNullOrWhiteSpace(user.FullName) ? "—" : user.FullName)</td>
                <td>@user.Email</td>
                <td>@(string.IsNullOrWhiteSpace(user.UserName) ? "—" : user.UserName)</td>
                <td>
                    <div class="inline-badges">
                        @foreach (var role in user.Roles)
                        {
                            <span class="badge">@role</span>
                        }
                    </div>
                </td>
                <td>@user.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")</td>
            </tr>
        }
        </tbody>
    </table>
</section>

<partial name="_PaginationPartial" model="(PaginationViewModel)ViewBag.Pagination" />
