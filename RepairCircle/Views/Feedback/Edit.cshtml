@model FeedbackFormViewModel
@{
    ViewData["Title"] = "Edit Feedback";
}

<section class="page-header card">
    <span class="eyebrow">Feedback</span>
    <h1>Edit feedback</h1>
    <p>Repair request: <strong>@Model.RepairRequestTitle</strong></p>
</section>

<section class="card">
    <form method="post">
        @Html.AntiForgeryToken()
        <partial name="_FeedbackFormPartial" model="Model" />
        <div class="actions">
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a class="btn btn-secondary" asp-controller="RepairRequests" asp-action="Details" asp-route-id="@Model.Input.RepairRequestId">Back to request</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
