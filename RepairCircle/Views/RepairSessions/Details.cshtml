@model RepairSessionDetailsViewModel
@{
    ViewData["Title"] = "Repair Session Details";
}

<section class="detail-grid">
    <article class="card detail-primary">
        <div class="item-card-topline">
            <span class="badge">@Model.LocationName</span>
            <span class="status-badge status-info">@Model.AvailableSlots / @Model.MaxParticipants slots</span>
        </div>
        <h1>@Model.Title</h1>
        <p class="lead">@Model.Description</p>
        <dl class="meta-list">
            <div>
                <dt>Starts</dt>
                <dd>@Model.StartDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
            </div>
            <div>
                <dt>Ends</dt>
                <dd>@Model.EndDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
            </div>
            <div>
                <dt>Location</dt>
                <dd>@Model.Address, @Model.City</dd>
            </div>
        </dl>
        <partial name="_LocationMapPartial" model="new RepairCircle.ViewModels.Common.MapEmbedViewModel
        {
            Title = Model.LocationName,
            AddressLine = Model.Address,
            City = Model.City,
            Latitude = Model.Latitude,
            Longitude = Model.Longitude
        }" />
    </article>

    <aside class="card detail-sidebar">
        <h2>Session planning</h2>
        <p>Each repair session can be linked to volunteers and open repair requests so the workshop can prepare tools and assignments in advance.</p>
    </aside>
</section>

<section class="grid grid-2 top-margin">
    <article class="card">
        <h2>Volunteers</h2>
        @if (!Model.VolunteerNames.Any())
        {
            <p class="muted">No volunteers assigned yet.</p>
        }
        else
        {
            <ul class="plain-list">
                @foreach (var volunteerName in Model.VolunteerNames)
                {
                    <li>@volunteerName</li>
                }
            </ul>
        }
    </article>

    <article class="card">
        <h2>Linked repair requests</h2>
        @if (!Model.RepairRequestTitles.Any())
        {
            <p class="muted">No repair requests linked yet.</p>
        }
        else
        {
            <ul class="plain-list">
                @foreach (var requestTitle in Model.RepairRequestTitles)
                {
                    <li>@requestTitle</li>
                }
            </ul>
        }
    </article>
</section>
