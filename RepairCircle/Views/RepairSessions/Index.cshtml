@model IReadOnlyCollection<RepairSessionListItemViewModel>
@{
    ViewData["Title"] = "Repair Sessions";
}

<section class="card">
    <h1>Repair Sessions</h1>
    <p>Upcoming community repair sessions.</p>
</section>

<section class="grid grid-2">
    @foreach (var session in Model)
    {
        <article class="card">
            <h2>@session.Title</h2>
            <p>@session.Description</p>
            <p><strong>When:</strong> @session.StartDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm") - @session.EndDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
            <p><strong>Slots:</strong> @session.AvailableSlots / @session.MaxParticipants</p>
            <p><strong>Location:</strong> @session.LocationName, @session.City</p>
            <a class="btn btn-secondary" asp-action="Details" asp-route-id="@session.Id">Details</a>
        </article>
    }
</section>
