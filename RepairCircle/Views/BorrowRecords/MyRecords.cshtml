@using Microsoft.AspNetCore.WebUtilities
@using System.Globalization
@using System.Linq
@model BorrowRecordIndexViewModel
@{
    ViewData["Title"] = ViewData["Title"] ?? "Borrow Records";
    var pageTitle = (ViewData["Title"] as string) ?? "Borrow Records";
    var isAdminView = string.Equals(pageTitle, "All Borrow Records", StringComparison.OrdinalIgnoreCase);
    var viewModel = Model ?? new BorrowRecordIndexViewModel();
    var items = viewModel.Items ?? Array.Empty<BorrowRecordListItemViewModel>();
    var statuses = viewModel.Statuses ?? Array.Empty<string>();
    var pager = viewModel.Pagination ?? new PaginationViewModel();

    string BuildPageUrl(int pageNumber)
    {
        var query = Context.Request.Query.ToDictionary(kvp => kvp.Key, kvp => (string?)kvp.Value.ToString());
        query["page"] = pageNumber.ToString(CultureInfo.InvariantCulture);
        return QueryHelpers.AddQueryString(Context.Request.Path, query);
    }

    var startPage = Math.Max(1, pager.CurrentPage - 2);
    var endPage = Math.Min(pager.TotalPages, pager.CurrentPage + 2);
}

<section class="page-header card">
    <span class="eyebrow">@(isAdminView ? "Administration" : "Personal history")</span>
    <h1>@(isAdminView ? "All borrow records" : "My borrow records")</h1>
    <p>@(isAdminView ? "Monitor borrowing requests across the whole platform." : "Track active, approved, and returned tool requests from one place.")</p>
</section>

<section class="card filter-card">
    <form method="get" class="form-grid filter-grid">
        <div class="form-field">
            <label for="searchTerm">Search</label>
            <input id="searchTerm" name="searchTerm" value="@viewModel.SearchTerm" placeholder="Tool name, BOR- reference, location..." />
        </div>
        <div class="form-field">
            <label for="status">Status</label>
            <select id="status" name="status">
                <option value="">All statuses</option>
                @foreach (var status in statuses)
                {
                    var isSelected = string.Equals(viewModel.Status, status, StringComparison.OrdinalIgnoreCase);
                    <option value="@status" selected="@(isSelected ? "selected" : null)">@status</option>
                }
            </select>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" href="@Url.Action(isAdminView ? "Index" : "MyRecords", "BorrowRecords")">Clear</a>
        </div>
    </form>
</section>

@if (!items.Any())
{
    <section class="empty-state">
        <h2>@(isAdminView ? "No borrowing records found" : "No borrowing records yet")</h2>
        <p>@(isAdminView ? "Borrowings will appear here after users submit requests." : "Borrowed tools will appear here after your first request.")</p>
    </section>
}
else
{
    <section class="card table-card">
        <table>
            <thead>
                <tr>
                    <th>Tool</th>
                    <th>Reference</th>
                    <th>Borrowed</th>
                    <th>Due</th>
                    <th>Status</th>
                    <th>Location</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var record in items)
            {
                <tr>
                    <td>@(record.ToolName ?? "Unknown tool")</td>
                    <td><code>@(record.BorrowReference ?? "N/A")</code></td>
                    <td>@record.BorrowDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                    <td>@record.DueDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                    <td>@await Html.PartialAsync("_BorrowStatusBadgePartial", record.Status)</td>
                    <td>@(record.LocationName ?? "Unknown location")</td>
                    <td><a href="@Url.Action("Details", "BorrowRecords", new { id = record.Id })">View code</a></td>
                </tr>
            }
            </tbody>
        </table>
    </section>

@if (pager.TotalPages > 1)
{
    <nav class="pagination-panel card" aria-label="Pagination navigation">
        <div class="pagination-summary">
            Showing <strong>@pager.StartItem</strong>–<strong>@pager.EndItem</strong> of <strong>@pager.TotalItems</strong> results
        </div>
        <div class="pagination-links">
            @if (pager.HasPreviousPage)
            {
                <a class="btn btn-secondary" href="@BuildPageUrl(pager.CurrentPage - 1)">Previous</a>
            }
            else
            {
                <span class="btn btn-secondary disabled" aria-disabled="true">Previous</span>
            }

            @for (var i = startPage; i <= endPage; i++)
            {
                if (i == pager.CurrentPage)
                {
                    <span class="pagination-link active">@i</span>
                }
                else
                {
                    <a class="pagination-link" href="@BuildPageUrl(i)">@i</a>
                }
            }

            @if (pager.HasNextPage)
            {
                <a class="btn btn-secondary" href="@BuildPageUrl(pager.CurrentPage + 1)">Next</a>
            }
            else
            {
                <span class="btn btn-secondary disabled" aria-disabled="true">Next</span>
            }
        </div>
    </nav>
}

}
