@model BorrowRecordIndexViewModel
@{
    ViewData["Title"] = "My Borrow Records";
}

<section class="page-header card">
    <span class="eyebrow">Personal history</span>
    <h1>My borrow records</h1>
    <p>Track active, approved, and returned tool requests from one place.</p>
</section>

<section class="card filter-card">
    <form method="get" class="form-grid filter-grid">
        <div class="form-field">
            <label asp-for="SearchTerm">Search</label>
            <input asp-for="SearchTerm" placeholder="Tool name, BOR- reference, location..." />
        </div>
        <div class="form-field">
            <label asp-for="Status">Status</label>
            <select asp-for="Status">
                <option value="">All statuses</option>
                @foreach (var status in Model.Statuses)
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="MyRecords">Clear</a>
        </div>
    </form>
</section>

@if (!Model.Items.Any())
{
    <section class="empty-state">
        <h2>No borrowing records yet</h2>
        <p>Borrowed tools will appear here after your first request.</p>
    </section>
}
else
{
    <section class="card table-card">
        <table>
            <thead>
                <tr>
                    <th>Tool</th>
                    <th>Reference</th>
                    <th>Borrowed</th>
                    <th>Due</th>
                    <th>Status</th>
                    <th>Location</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var record in Model.Items)
            {
                <tr>
                    <td>@record.ToolName</td>
                    <td><code>@record.BorrowReference</code></td>
                    <td>@record.BorrowDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                    <td>@record.DueDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                    <td><partial name="_BorrowStatusBadgePartial" model="record.Status" /></td>
                    <td>@record.LocationName</td>
                </tr>
            }
            </tbody>
        </table>
    </section>
}

<partial name="_PaginationPartial" model="Model.Pagination" />
