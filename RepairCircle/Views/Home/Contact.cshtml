@{
    ViewData["Title"] = "Contact";
}

<section class="page-header card">
    <span class="eyebrow">Get in touch</span>
    <h1>Contact RepairCircle</h1>
    <p>This page can later be connected to a real contact form or support workflow.</p>
</section>

<section class="grid grid-2">
    <article class="card">
        <h2>General support</h2>
        <dl class="meta-list">
            <div>
                <dt>Email</dt>
                <dd>hello@repaircircle.local</dd>
            </div>
            <div>
                <dt>Phone</dt>
                <dd>+359 000 000 000</dd>
            </div>
            <div>
                <dt>Office hours</dt>
                <dd>Monday – Friday, 09:00 – 18:00</dd>
            </div>
        </dl>
    </article>
    <article class="card">
        <h2>Community workshops</h2>
        <p>The app can now embed Google Maps for workshop and pickup locations. Below is a demo map pointing to Sofia so the feature is visible even before you add more location pages.</p>
        <div class="actions">
            <a class="btn btn-secondary" asp-controller="RepairSessions" asp-action="Index">View repair sessions</a>
            <a class="btn btn-secondary" asp-controller="Tools" asp-action="Index">Browse tools</a>
        </div>
    </article>
</section>


<section class="card top-margin">
    <partial name="_LocationMapPartial" model="new RepairCircle.ViewModels.Common.MapEmbedViewModel
    {
        Title = "RepairCircle Sofia Demo Location",
        AddressLine = "Sofia Center",
        City = "Sofia",
        Latitude = 42.697708m,
        Longitude = 23.321868m
    }" />
</section>
