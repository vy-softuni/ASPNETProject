@model HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero hero-split">
    <div>
        <span class="eyebrow">Community repair and tool sharing</span>
        <h1>Repair more. Waste less. Help each other.</h1>
        <p class="lead">RepairCircle connects residents, volunteers, and community workshops so broken items get fixed and useful tools keep circulating.</p>
        <p class="muted">Registered users create private repair requests that are visible to themselves and administrators.</p>
        <div class="actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-primary" asp-controller="RepairRequests" asp-action="Create">Submit a repair request</a>
                <a class="btn btn-secondary" asp-controller="RepairRequests" asp-action="MyRequests">View my repair requests</a>
            }
            else
            {
                <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Register">Create account to request a repair</a>
                <a class="btn btn-secondary" asp-area="Identity" asp-page="/Account/Login">Log in</a>
            }
            <a class="btn btn-secondary" asp-controller="Tools" asp-action="Index">Browse tools</a>
            <a class="btn btn-secondary" asp-controller="Volunteers" asp-action="BecomeOne">Become a volunteer</a>
        </div>
    </div>
    <div class="hero-card stat-panel">
        <h2>Community snapshot</h2>
        <div class="stat-grid">
            <div class="stat-box">
                <span class="stat-number">@Model.AvailableToolsCount</span>
                <span class="stat-label">Available tools</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@Model.ActiveRepairRequestsCount</span>
                <span class="stat-label">Active requests</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@Model.UpcomingSessionsCount</span>
                <span class="stat-label">Upcoming sessions</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@Model.ApprovedVolunteersCount</span>
                <span class="stat-label">Approved volunteers</span>
            </div>
        </div>
    </div>
</section>

<section class="section-header">
    <div>
        <span class="eyebrow">Featured tools</span>
        <h2>Popular tools ready to borrow</h2>
    </div>
    <a class="btn btn-secondary" asp-controller="Tools" asp-action="Index">View all tools</a>
</section>

@if (!Model.FeaturedTools.Any())
{
    <section class="empty-state">
        <h3>No tools are featured yet</h3>
        <p>Seeded or admin-created tools will appear here.</p>
    </section>
}
else
{
    <section class="grid grid-3">
        @foreach (var tool in Model.FeaturedTools)
        {
            <partial name="_ToolCardPartial" model="tool" />
        }
    </section>
}


<section class="section-header top-margin">
    <div>
        <span class="eyebrow">Quick return</span>
        <h2>Recently viewed tools</h2>
    </div>
    <a class="btn btn-secondary" asp-controller="Tools" asp-action="Index">Browse all tools</a>
</section>

<section class="recent-tools-home" data-recent-tools-root hidden>
    <div class="grid grid-3" data-recent-tools-list></div>
</section>

<section class="section-header top-margin">
    <div>
        <span class="eyebrow">News and notices</span>
        <h2>Latest announcements</h2>
    </div>
</section>

@if (!Model.LatestAnnouncements.Any())
{
    <section class="empty-state">
        <h3>No announcements yet</h3>
        <p>Important updates from the platform will appear here.</p>
    </section>
}
else
{
    <section class="stack-list">
        @foreach (var announcement in Model.LatestAnnouncements)
        {
            <article class="card announcement-card">
                <div class="item-card-topline">
                    <strong>@announcement.Title</strong>
                    @if (announcement.IsImportant)
                    {
                        <span class="status-badge status-warning">Important</span>
                    }
                </div>
                <p>@announcement.Content</p>
                <p class="muted small-text">Published on @announcement.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy")</p>
            </article>
        }
    </section>
}



<section class="grid grid-3 top-margin">
    <article class="card feature-card">
        <span class="eyebrow">Borrow</span>
        <h3>Share tools locally</h3>
        <p class="muted">Residents can find useful tools, check availability, and submit borrowing requests with generated references.</p>
    </article>
    <article class="card feature-card">
        <span class="eyebrow">Repair</span>
        <h3>Reduce waste together</h3>
        <p class="muted">Repair requests connect item owners with volunteers and community sessions in a structured workflow.</p>
    </article>
    <article class="card feature-card">
        <span class="eyebrow">Coordinate</span>
        <h3>Manage the platform</h3>
        <p class="muted">The admin area provides charts, CRUD management, live notifications, and moderation tools.</p>
    </article>
</section>



@section Scripts {
    <script src="~/js/recent-tools.js" asp-append-version="true"></script>
}