@model HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <div>
        <span class="eyebrow">Community repair and tool sharing</span>
        <h1>Welcome to RepairCircle</h1>
        <p>RepairCircle helps communities fix broken items, borrow tools, and connect with volunteers who can help.</p>
        <div class="actions">
            <a class="btn btn-primary" asp-controller="RepairRequests" asp-action="Create">Submit a Repair Request</a>
            <a class="btn btn-secondary" asp-controller="Tools" asp-action="Index">Browse Tools</a>
        </div>
    </div>
    <div class="hero-card">
        <h2>Community Snapshot</h2>
        <ul>
            <li><strong>@Model.AvailableToolsCount</strong> available tools</li>
            <li><strong>@Model.ActiveRepairRequestsCount</strong> active repair requests</li>
            <li><strong>@Model.UpcomingSessionsCount</strong> upcoming repair sessions</li>
            <li><strong>@Model.ApprovedVolunteersCount</strong> approved volunteers</li>
        </ul>
    </div>
</section>

<section class="grid grid-3">
    @foreach (var tool in Model.FeaturedTools)
    {
        <article class="card">
            <h3>@tool.Name</h3>
            <p>@tool.Description</p>
            <p><strong>@tool.CategoryName</strong> · @tool.LocationName</p>
            <a class="btn btn-secondary" asp-controller="Tools" asp-action="Details" asp-route-id="@tool.Id">View tool</a>
        </article>
    }
</section>

<section class="card">
    <h2>Latest announcements</h2>
    @if (!Model.LatestAnnouncements.Any())
    {
        <p>No announcements yet.</p>
    }
    else
    {
        <ul>
            @foreach (var announcement in Model.LatestAnnouncements)
            {
                <li>
                    <strong>@announcement.Title</strong>
                    @if (announcement.IsImportant)
                    {
                        <span> - Important</span>
                    }
                    <br />
                    <span>@announcement.Content</span>
                </li>
            }
        </ul>
    }
</section>
