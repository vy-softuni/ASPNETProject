@model RepairCircle.Models.StatusCodeErrorViewModel
@{
    ViewData["Title"] = "Not Found";
}
<section class="empty-state large-empty">
    <div class="status-code">404</div>
    <h1>We could not find that page</h1>
    <p>The link may be outdated, the address may be incorrect, or the resource may have been removed.</p>

    @if (!string.IsNullOrWhiteSpace(Model.FullOriginalUrl))
    {
        <p class="error-meta"><strong>Requested path:</strong> <code>@Model.FullOriginalUrl</code></p>
    }

    @if (Model.ShowRequestId)
    {
        <p class="error-meta"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }

    <div class="actions center-actions">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Back to home</a>
        <a class="btn btn-secondary" asp-controller="Tools" asp-action="Index">Browse tools</a>
    </div>
</section>
