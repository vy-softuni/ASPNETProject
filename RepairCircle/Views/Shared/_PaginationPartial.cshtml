@using Microsoft.AspNetCore.WebUtilities
@model PaginationViewModel

@if (Model.TotalPages > 1)
{
    string BuildPageUrl(int pageNumber)
    {
        var query = Context.Request.Query.ToDictionary(kvp => kvp.Key, kvp => kvp.Value.ToString());
        query["page"] = pageNumber.ToString();
        return QueryHelpers.AddQueryString(Context.Request.Path, query!);
    }

    var startPage = Math.Max(1, Model.CurrentPage - 2);
    var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);

    <nav class="pagination-panel card" aria-label="Pagination navigation">
        <div class="pagination-summary">
            Showing <strong>@Model.StartItem</strong>–<strong>@Model.EndItem</strong> of <strong>@Model.TotalItems</strong> results
        </div>
        <div class="pagination-links">
            <a class="btn btn-secondary @(Model.HasPreviousPage ? string.Empty : "disabled")"
               href="@(Model.HasPreviousPage ? BuildPageUrl(Model.CurrentPage - 1) : "#")"
               aria-disabled="@(!Model.HasPreviousPage)">Previous</a>

            @for (var i = startPage; i <= endPage; i++)
            {
                <a class="pagination-link @(i == Model.CurrentPage ? "active" : string.Empty)" href="@BuildPageUrl(i)">@i</a>
            }

            <a class="btn btn-secondary @(Model.HasNextPage ? string.Empty : "disabled")"
               href="@(Model.HasNextPage ? BuildPageUrl(Model.CurrentPage + 1) : "#")"
               aria-disabled="@(!Model.HasNextPage)">Next</a>
        </div>
    </nav>
}
