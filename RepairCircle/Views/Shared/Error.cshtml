@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="card">
    <h1>Something went wrong.</h1>
    <p>We could not process your request.</p>

    @if (Model.ShowRequestId)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }

    <p class="text-muted">You can return to the home page or try the action again.</p>
    <div class="actions">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Home</a>
        <a class="btn btn-secondary" asp-controller="Home" asp-action="Contact">Contact support</a>
    </div>
</section>
