<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RepairCircle</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="site-header">
        <div class="container nav-wrap">
            <a class="brand" asp-controller="Home" asp-action="Index">RepairCircle</a>
            <nav class="main-nav">
                <a asp-controller="Home" asp-action="About">About</a>
                <a asp-controller="Tools" asp-action="Index">Tools</a>
                <a asp-controller="RepairSessions" asp-action="Index">Sessions</a>
                <a asp-controller="Volunteers" asp-action="Index">Volunteers</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="RepairRequests" asp-action="Create">Request Repair</a>
                    <a asp-controller="RepairRequests" asp-action="MyRequests">My Repairs</a>
                    <a asp-controller="BorrowRecords" asp-action="MyRecords">My Borrowings</a>
                    <a asp-controller="Favorites" asp-action="Index">Favorites</a>
                }
                <a asp-controller="Home" asp-action="Contact">Contact</a>
                @if (User.IsInRole("Administrator"))
                {
                    <a asp-controller="RepairRequests" asp-action="Index">All Repairs</a>
                    <a asp-controller="BorrowRecords" asp-action="Index">All Borrowings</a>
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                }
            </nav>
            <partial name="_LoginPartial" />
        </div>
    </header>

    <main class="container page-content">
        <partial name="~/Views/Shared/_StatusMessage.cshtml" />
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-content">
            <div>
                <strong>RepairCircle</strong>
                <p>Community repair, tool sharing, and volunteer coordination.</p>
            </div>
            <div class="footer-links">
                <a asp-controller="Tools" asp-action="Index">Browse tools</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="RepairRequests" asp-action="Create">Request a repair</a>
                    <a asp-controller="Volunteers" asp-action="BecomeOne">Become a volunteer</a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login">Log in to request a repair</a>
                    <a asp-area="Identity" asp-page="/Account/Login">Log in to become a volunteer</a>
                }
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
