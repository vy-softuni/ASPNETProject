@model string?
@{
    var statusText = string.IsNullOrWhiteSpace(Model) ? "Unknown" : Model;
    var cssClass = statusText.ToLowerInvariant() switch
    {
        "approved" => "status-success",
        "returned" => "status-info",
        "overdue" => "status-danger",
        "rejected" => "status-danger",
        _ => "status-warning"
    };
}
<span class="status-badge @cssClass">@statusText</span>
