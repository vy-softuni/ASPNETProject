@model FeedbackFormViewModel
<div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
<input asp-for="Input.Id" type="hidden" />
<input asp-for="Input.RepairRequestId" type="hidden" />

<div class="form-grid">
    <div class="form-field">
        <label asp-for="Input.Rating"></label>
        <input asp-for="Input.Rating" type="number" min="1" max="5" />
        <small class="form-hint">Use whole numbers from 1 to 5.</small>
        <span asp-validation-for="Input.Rating"></span>
    </div>
    <div class="form-field form-field-wide">
        <label asp-for="Input.Comment"></label>
        <textarea asp-for="Input.Comment" placeholder="Share what went well and what could be improved."></textarea>
        <span asp-validation-for="Input.Comment"></span>
    </div>
</div>
