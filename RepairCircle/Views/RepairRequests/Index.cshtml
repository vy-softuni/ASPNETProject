@model RepairRequestIndexViewModel
@{
    ViewData["Title"] = "Repair Requests";
}

<section class="card">
    <h1>Repair Requests</h1>
    <p>Community-submitted repair requests.</p>
</section>

<section class="grid grid-2">
    @foreach (var request in Model.Requests)
    {
        <article class="card">
            <h2>@request.Title</h2>
            <p><strong>Item type:</strong> @request.ItemType</p>
            <p><strong>Status:</strong> @request.Status</p>
            <p><strong>Submitted by:</strong> @request.SubmittedBy</p>
            <p><strong>Volunteer:</strong> @(request.AssignedVolunteer ?? "Not assigned")</p>
            <p><strong>Location:</strong> @request.LocationName</p>
            <a class="btn btn-secondary" asp-action="Details" asp-route-id="@request.Id">Details</a>
        </article>
    }
</section>
