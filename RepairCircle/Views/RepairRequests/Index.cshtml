@model RepairRequestIndexViewModel
@{
    ViewData["Title"] = ViewData["Title"] as string ?? "Repair Requests";
}

<section class="page-header card">
    <span class="eyebrow">Repair workflow</span>
    <h1>@ViewData["Title"]</h1>
    <p>Browse submitted requests and review their current assignment and status.</p>
</section>

<section class="card filter-card">
    <form method="get" class="form-grid filter-grid">
        <div class="form-field">
            <label asp-for="SearchTerm">Search</label>
            <input asp-for="SearchTerm" placeholder="Lamp, bicycle chain, toaster, Sofia..." />
        </div>
        <div class="form-field">
            <label asp-for="Status">Status</label>
            <select asp-for="Status">
                <option value="">All statuses</option>
                @foreach (var status in Model.Statuses)
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>
        <div class="form-field">
            <label asp-for="LocationId">Location</label>
            <select asp-for="LocationId">
                <option value="">All locations</option>
                @foreach (var location in Model.Locations)
                {
                    <option value="@location.Id">@location.Name</option>
                }
            </select>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="@(ViewData["Title"]?.ToString() == "My Repair Requests" ? "MyRequests" : "Index")">Clear</a>
        </div>
    </form>
</section>

@if (!Model.Requests.Any())
{
    <section class="empty-state">
        <h2>No repair requests found</h2>
        <p>New requests will appear here once users start submitting items for repair.</p>
    </section>
}
else
{
    <section class="grid grid-2">
        @foreach (var request in Model.Requests)
        {
            <partial name="_RepairRequestCardPartial" model="request" />
        }
    </section>
}

<partial name="_PaginationPartial" model="Model.Pagination" />
