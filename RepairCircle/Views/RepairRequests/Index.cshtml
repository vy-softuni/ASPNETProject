@using System.Linq
@model RepairRequestIndexViewModel
@{
    ViewData["Title"] = ViewData["Title"] as string ?? "Repair Requests";
    var requests = Model?.Requests ?? Array.Empty<RepairRequestListItemViewModel>();
    var locations = Model?.Locations ?? Array.Empty<LookupViewModel>();
    var statuses = Model?.Statuses ?? Array.Empty<string>();
}

<section class="page-header card">
    <span class="eyebrow">Repair workflow</span>
    <h1>@ViewData["Title"]</h1>
    <p>Browse submitted requests and review their current assignment and status.</p>
</section>

<section class="card filter-card">
    <form method="get" class="form-grid filter-grid">
        <div class="form-field">
            <label asp-for="SearchTerm">Search</label>
            <input asp-for="SearchTerm" placeholder="Lamp, bicycle chain, toaster, Sofia..." />
        </div>
        <div class="form-field">
            <label asp-for="Status">Status</label>
            <select asp-for="Status">
                <option value="">All statuses</option>
                @foreach (var status in statuses)
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>
        <div class="form-field">
            <label asp-for="LocationId">Location</label>
            <select asp-for="LocationId">
                <option value="">All locations</option>
                @foreach (var location in locations)
                {
                    <option value="@location.Id">@location.Name</option>
                }
            </select>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="@(ViewData["Title"]?.ToString() == "My Repair Requests" ? "MyRequests" : "Index")">Clear</a>
        </div>
    </form>
</section>

@if (!requests.Any())
{
    <section class="empty-state">
        <h2>No repair requests found</h2>
        <p>Try different filters or add a new request.</p>
    </section>
}
else
{
    <section class="grid grid-2">
        @foreach (var request in requests)
        {
            <article class="card item-card">
                <div class="item-card-topline">
                    <span class="badge">@request.ItemType</span>
                    <span class="status-badge">@request.Status</span>
                </div>
                <h3>@request.Title</h3>
                <p><strong>Submitted by:</strong> @request.SubmittedBy</p>
                <p><strong>Volunteer:</strong> @(request.AssignedVolunteer ?? "Awaiting assignment")</p>
                <p><strong>Location:</strong> @request.LocationName</p>
                <p><strong>Requested on:</strong> @request.RequestedDate.ToLocalTime().ToString("dd.MM.yyyy")</p>
                <div class="actions">
                    <a class="btn btn-secondary" asp-controller="RepairRequests" asp-action="Details" asp-route-id="@request.Id">Open request</a>
                </div>
            </article>
        }
    </section>
}
