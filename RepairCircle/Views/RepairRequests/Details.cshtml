@model RepairRequestDetailsViewModel
@{
    ViewData["Title"] = "Repair Request Details";
}

<section class="detail-grid">
    <article class="card detail-primary">
        <div class="item-card-topline">
            <span class="badge">@Model.ItemType</span>
            <span class="status-badge">@Model.Status</span>
        </div>
        <h1>@Model.Title</h1>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img class="detail-image" src="@Url.Content(Model.ImageUrl)" alt="Image for repair request @Model.Title" />
        }
        <p class="lead">@Model.Description</p>

        <dl class="meta-list">
            <div>
                <dt>Submitted by</dt>
                <dd>@Model.SubmittedBy</dd>
            </div>
            <div>
                <dt>Volunteer</dt>
                <dd>@(Model.AssignedVolunteer ?? "Not assigned yet")</dd>
            </div>
            <div>
                <dt>Location</dt>
                <dd>@Model.LocationName, @Model.City</dd>
            </div>
            <div>
                <dt>Repair session</dt>
                <dd>@(Model.RepairSessionTitle ?? "Independent request")</dd>
            </div>
            <div>
                <dt>Request reference</dt>
                <dd><code>@Model.RequestReference</code></dd>
            </div>
            <div>
                <dt>Requested on</dt>
                <dd>@Model.RequestedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
            </div>
        </dl>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="actions">
                <a class="btn btn-primary" asp-controller="Feedback" asp-action="Create" asp-route-repairRequestId="@Model.Id">Leave feedback</a>
                <a class="btn btn-secondary" asp-controller="RepairRequests" asp-action="MyRequests">My requests</a>
            </div>
        }
    </article>

    <aside class="card detail-sidebar">
        <h2>Repair lifecycle</h2>
        <partial name="_ReferenceCodePartial" model="Model.RequestReference" />
        <ol class="plain-list numbered-list">
            <li>Request submitted by the user.</li>
            <li>Volunteer or admin reviews the issue.</li>
            <li>Request may be linked to a repair session.</li>
            <li>User can leave feedback after completion.</li>
        </ol>
        <partial name="_LocationMapPartial" model="new RepairCircle.ViewModels.Common.MapEmbedViewModel
        {
            Title = Model.LocationName,
            AddressLine = Model.Address,
            City = Model.City,
            Latitude = Model.Latitude,
            Longitude = Model.Longitude
        }" />
    </aside>
</section>

<section class="card top-margin">
    <h2>Feedback</h2>
    <partial name="_FeedbackListPartial" model="Model.Feedback" />
</section>
