@model RepairRequestCreateViewModel
@{
    ViewData["Title"] = "Create Repair Request";
}

<section class="page-header card">
    <span class="eyebrow">New request</span>
    <h1>Create a repair request</h1>
    <p>Describe the item, choose a location, and optionally link the request to an available repair session.</p>
</section>

<section class="card">
    <form id="repair-request-form" asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="draft-tools">
            <p id="repair-request-draft-status" class="muted small-text local-storage-message" aria-live="polite"></p>
            <div class="actions">
                <button class="btn btn-secondary" type="button" id="restore-repair-draft-button">Restore saved draft</button>
                <button class="btn btn-secondary" type="button" id="clear-repair-draft-button">Discard saved draft</button>
            </div>
        </div>

        <div class="form-grid">
            <div class="form-field form-field-wide">
                <label asp-for="Input.Title"></label>
                <input asp-for="Input.Title" placeholder="Example: Electric kettle not heating" maxlength="120" />
                <span asp-validation-for="Input.Title"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.ItemType"></label>
                <input asp-for="Input.ItemType" placeholder="Appliance, bicycle, sewing machine..." maxlength="80" />
                <span asp-validation-for="Input.ItemType"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.LocationId">Location</label>
                <select asp-for="Input.LocationId">
                    <option value="">Select location</option>
                    @foreach (var location in Model.Locations)
                    {
                        <option value="@location.Id">@location.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.LocationId"></span>
            </div>

            <div class="form-field form-field-wide">
                <label asp-for="Input.Description"></label>
                <textarea asp-for="Input.Description" placeholder="Explain the issue, symptoms, and any previous repair attempts."></textarea>
                <span asp-validation-for="Input.Description"></span>
            </div>

            <div class="form-field form-field-wide">
                <label asp-for="Input.ImageUrl"></label>
                <input asp-for="Input.ImageUrl" placeholder="Optional direct image URL (or leave blank if you upload a photo below)" />
                <span asp-validation-for="Input.ImageUrl"></span>
            </div>

            <div class="form-field form-field-wide">
                <label asp-for="Input.UploadedImage"></label>
                <input asp-for="Input.UploadedImage" type="file" accept=".jpg,.jpeg,.png,.webp,.gif,image/*" />
                <span asp-validation-for="Input.UploadedImage"></span>
                <small class="muted small-text">Optional. You can either paste a direct image link above or upload a clear photo here to help volunteers evaluate the repair.</small>
            </div>

            <div class="form-field form-field-wide">
                <label asp-for="Input.RepairSessionId">Repair session</label>
                <select asp-for="Input.RepairSessionId">
                    <option value="">No session yet</option>
                    @foreach (var session in Model.RepairSessions)
                    {
                        <option value="@session.Id">@session.Name</option>
                    }
                </select>
            </div>
        </div>

        <div class="actions">
            <button class="btn btn-primary" type="submit">Submit request</button>
            <a class="btn btn-secondary" asp-action="Index">Back to requests</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/repair-request-draft.js" asp-append-version="true"></script>
}
