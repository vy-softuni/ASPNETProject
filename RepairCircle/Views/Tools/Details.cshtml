@model ToolDetailsViewModel
@{
    ViewData["Title"] = "Tool Details";

    var recentToolPayload = new
    {
        id = Model.Id,
        name = Model.Name,
        url = Url.Action("Details", "Tools", new { id = Model.Id }),
        categoryName = Model.CategoryName,
        locationName = Model.LocationName,
        imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl) ? null : Url.Content(Model.ImageUrl),
        isAvailable = Model.IsAvailable
    };

    var mapModel = new RepairCircle.ViewModels.Common.MapEmbedViewModel
    {
        Title = Model.LocationName,
        AddressLine = Model.Address,
        City = Model.City,
        Latitude = Model.Latitude,
        Longitude = Model.Longitude
    };
}

<section class="detail-grid">
    <article class="card detail-primary">
        <div class="item-card-topline">
            <span class="badge">@Model.CategoryName</span>
            <span id="tool-availability-badge" class="status-badge @(Model.IsAvailable ? "status-success" : "status-muted")">@(Model.IsAvailable ? "Available" : "Unavailable")</span>
        </div>
        <h1>@Model.Name</h1>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img class="detail-image" src="@Url.Content(Model.ImageUrl)" alt="Image of @Model.Name" />
        }
        <p class="lead">@Model.Description</p>

        <dl class="meta-list">
            <div>
                <dt>Condition</dt>
                <dd>@Model.Condition</dd>
            </div>
            <div>
                <dt>Quantity</dt>
                <dd id="tool-quantity">@Model.Quantity</dd>
            </div>
            <div>
                <dt>Favorites</dt>
                <dd id="tool-favorites-count">@Model.FavoritesCount</dd>
            </div>
            <div>
                <dt>Borrow records</dt>
                <dd>@Model.BorrowRecordsCount</dd>
            </div>
            <div>
                <dt>Location</dt>
                <dd>@Model.LocationName, @Model.City</dd>
            </div>
            <div>
                <dt>Address</dt>
                <dd>@Model.Address</dd>
            </div>
        </dl>

        @await Html.PartialAsync("_LocationMapPartial", mapModel)

        <div id="tool-live-status" class="live-status-box">
            Waiting for live availability updates.
        </div>

        <div id="favorite-toggle-status" class="ajax-status-message" hidden></div>

        <div class="actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-primary" asp-controller="BorrowRecords" asp-action="Create" asp-route-toolId="@Model.Id">Borrow this tool</a>
                <form asp-controller="Favorites"
                      asp-action="ToggleAjax"
                      method="post"
                      class="inline-form"
                      id="favorite-toggle-form"
                      data-ajax-favorite-form
                      data-tool-id="@Model.Id"
                      data-add-label="Add to favorites"
                      data-remove-label="Remove from favorites">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="toolId" value="@Model.Id" />
                    <button type="submit" class="btn btn-secondary" data-favorite-toggle-button>
                        @(Model.IsFavoritedByCurrentUser ? "Remove from favorites" : "Add to favorites")
                    </button>
                </form>
            }
            <a class="btn btn-secondary" asp-controller="Tools" asp-action="Index">Back to tools</a>
        </div>
    </article>

    <aside class="detail-sidebar-stack">
        <section class="card detail-sidebar">
            <h2>Borrowing guidance</h2>
            <ul>
                <li>Pick up the tool from the listed location.</li>
                <li>Choose a due date when creating the borrowing record.</li>
                <li>Availability depends on the current quantity and approval workflow.</li>
                <li>This page now updates live when another borrowing request reserves the tool.</li>
            </ul>
        </section>

        <section class="card recent-tools-card" data-recent-tools-root hidden>
            <h2>Recently viewed tools</h2>
            <p class="muted small-text">Stored locally in this browser for quick return visits.</p>
            <div class="recent-tools-list" data-recent-tools-list></div>
        </section>
    </aside>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        window.repairCircleToolRealtime = {
            toolId: @Model.Id,
            initiallyAvailable: @Model.IsAvailable.ToString().ToLowerInvariant()
        };
        window.repairCircleRecentTool = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(recentToolPayload));
    </script>
    <script src="~/js/realtime-tool-details.js" asp-append-version="true"></script>
    <script src="~/js/recent-tools.js" asp-append-version="true"></script>
    <script src="~/js/ajax-favorites.js" asp-append-version="true"></script>
}
