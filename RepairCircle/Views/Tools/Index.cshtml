@model ToolIndexViewModel
@{
    ViewData["Title"] = "Tools";
}

<section class="page-header card">
    <span class="eyebrow">Tool inventory</span>
    <h1>Browse available tools</h1>
    <p>Search by name and narrow the results by category, location, condition, and availability.</p>
</section>

<section class="card filter-card">
    <form id="tool-filter-form" method="get" class="form-grid filter-grid">
        <div class="form-field">
            <label asp-for="SearchTerm">Search</label>
            <input asp-for="SearchTerm" placeholder="Drill, sewing machine, bike stand..." />
        </div>
        <div class="form-field">
            <label asp-for="CategoryId">Category</label>
            <select asp-for="CategoryId">
                <option value="">All categories</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
        <div class="form-field">
            <label asp-for="LocationId">Location</label>
            <select asp-for="LocationId">
                <option value="">All locations</option>
                @foreach (var location in Model.Locations)
                {
                    <option value="@location.Id">@location.Name</option>
                }
            </select>
        </div>
        <div class="form-field">
            <label asp-for="Condition">Condition</label>
            <select asp-for="Condition">
                <option value="">All conditions</option>
                @foreach (var condition in Model.Conditions)
                {
                    <option value="@condition">@condition</option>
                }
            </select>
        </div>
        <div class="form-field checkbox-field">
            <label class="checkbox-label">
                <input asp-for="OnlyAvailable" type="checkbox" value="true" />
                Show only available tools
            </label>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <button class="btn btn-secondary" type="button" id="save-tool-filters-button">Save these filters</button>
            <button class="btn btn-secondary" type="button" id="clear-tool-filters-button">Forget saved filters</button>
            <a class="btn btn-secondary" asp-action="Index">Clear</a>
        </div>
        <p id="saved-tool-filters-message" class="muted small-text local-storage-message" aria-live="polite"></p>
    </form>
</section>

@if (!Model.Tools.Any())
{
    <section class="empty-state">
        <h2>No tools match the current filters</h2>
        <p>Try broadening the search or removing some filters.</p>
    </section>
}
else
{
    <section class="grid grid-3">
        @foreach (var tool in Model.Tools)
        {
            <partial name="_ToolCardPartial" model="tool" />
        }
    </section>
}

<partial name="_PaginationPartial" model="Model.Pagination" />


@section Scripts {
    <script src="~/js/tool-filters-storage.js" asp-append-version="true"></script>
}