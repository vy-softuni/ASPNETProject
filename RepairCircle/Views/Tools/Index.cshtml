@using System.Linq
@model ToolIndexViewModel
@{
    ViewData["Title"] = "Tools";
    var items = Model?.Tools ?? Array.Empty<ToolListItemViewModel>();
    var categories = Model?.Categories ?? Array.Empty<LookupViewModel>();
    var locations = Model?.Locations ?? Array.Empty<LookupViewModel>();
    var conditions = Model?.Conditions ?? Array.Empty<string>();
}

<section class="page-header card">
    <span class="eyebrow">Tool inventory</span>
    <h1>Browse available tools</h1>
    <p>Find items you can borrow from the community workshops.</p>
</section>

<section class="card filter-card">
    <form method="get" class="form-grid filter-grid">
        <div class="form-field">
            <label asp-for="SearchTerm">Search</label>
            <input asp-for="SearchTerm" placeholder="Drill, sewing machine, bike stand..." />
        </div>
        <div class="form-field">
            <label asp-for="CategoryId">Category</label>
            <select asp-for="CategoryId">
                <option value="">All categories</option>
                @foreach (var category in categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
        <div class="form-field">
            <label asp-for="LocationId">Location</label>
            <select asp-for="LocationId">
                <option value="">All locations</option>
                @foreach (var location in locations)
                {
                    <option value="@location.Id">@location.Name</option>
                }
            </select>
        </div>
        <div class="form-field">
            <label asp-for="Condition">Condition</label>
            <select asp-for="Condition">
                <option value="">All conditions</option>
                @foreach (var condition in conditions)
                {
                    <option value="@condition">@condition</option>
                }
            </select>
        </div>
        <div class="form-field checkbox-field">
            <label class="checkbox-label">
                <input asp-for="OnlyAvailable" type="checkbox" value="true" /> Show only available tools
            </label>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-secondary" asp-action="Index">Clear</a>
        </div>
    </form>
</section>

@if (!items.Any())
{
    <section class="empty-state">
        <h2>No tools are available for the selected filters</h2>
        <p>Try a different search or remove some filters.</p>
    </section>
}
else
{
    <section class="grid grid-3">
        @foreach (var tool in items)
        {
            <article class="card item-card tool-card">
                @if (!string.IsNullOrWhiteSpace(tool.ImageUrl))
                {
                    <img class="item-card-image" src="@Url.Content(tool.ImageUrl)" alt="Image of @tool.Name" />
                }
                <div class="item-card-body">
                    <div class="item-card-topline">
                        <span class="badge">@tool.CategoryName</span>
                        <span class="status-badge @(tool.IsAvailable ? "status-success" : "status-muted")">@(tool.IsAvailable ? "Available" : "Unavailable")</span>
                    </div>
                    <h3>@tool.Name</h3>
                    <p class="muted">@tool.Description</p>
                    <p><strong>Condition:</strong> @tool.Condition</p>
                    <p><strong>Location:</strong> @tool.LocationName, @tool.City</p>
                    <p><strong>Quantity:</strong> @tool.Quantity</p>
                </div>
                <div class="actions">
                    <a class="btn btn-secondary" asp-controller="Tools" asp-action="Details" asp-route-id="@tool.Id">View details</a>
                </div>
            </article>
        }
    </section>
}
